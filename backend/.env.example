PROJECT_NAME=Cinema Showcase API
PROJECT_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
FRONTEND_BASE_URL=http://localhost:5173
MONGODB_URI=mongodb://localhost:27017/?replicaSet=rs0&directConnection=true
MONGODB_DB_NAME=cinema_showcase
JWT_SECRET_KEY=change-this-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=10080
LOG_LEVEL=INFO
LOG_FORMAT=text
LOG_FILE_ENABLED=true
LOG_FILE_LEVEL=INFO
PAYMENT_LOG_LEVEL=INFO
AUDIT_LOG_LEVEL=INFO
APP_LOG_FILE=logs/app.log
PAYMENTS_LOG_FILE=logs/payments.log
AUDIT_LOG_FILE=logs/audit.log
LOG_ROTATION_MAX_BYTES=10485760
LOG_ROTATION_BACKUP_COUNT=5
CINEMA_TIMEZONE=Europe/Kyiv
HALL_ROWS_COUNT=8
HALL_SEATS_PER_ROW=12
RESERVATION_HOLD_MINUTES=15
PAYMENT_PROVIDER=fake
PAYMENT_WEBHOOK_SECRET=fake-webhook-secret
FIRST_SESSION_HOUR=9
LAST_SESSION_START_HOUR=22
ADMIN_EMAILS=["admin@example.com"]
